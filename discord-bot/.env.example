# Discord Bot Token - get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Channel ID - right click channel > Copy Channel ID (enable Developer Mode first)
CHANNEL_ID=your_channel_id_here

# Ngrok Auth Token - get from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here

# Path to Minecraft server directory
MC_SERVER_DIR=/home/pi/CatBot_minecraft

# Minecraft server port (default 25565)
MC_PORT=25565
